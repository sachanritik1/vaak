{
  "name": "vaak",
  "version": "0.1.4",
  "description": "Vaak — open-source Wispr Flow alternative with local voice dictation",
  "main": "./out/main/index.js",
  "author": "Vaak Contributors",
  "license": "MIT",
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps && node scripts/install-parakeet.cjs",
    "prepare": "effect-language-service patch",
    "rebuild": "electron-builder install-app-deps",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:main": "vitest run --project main",
    "test:renderer": "vitest run --project renderer",
    "test:types": "vitest --typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "pnpm run lint && pnpm run format:check && pnpm run typecheck",
    "pack": "pnpm run build && electron-builder --dir",
    "dist": "pnpm run build && electron-builder",
    "release": "pnpm run build && electron-builder --publish always"
  },
  "dependencies": {
    "effect": "^4.0.0-beta.90",
    "electron-store": "^8.2.0",
    "smart-whisper": "^0.8.1",
    "uiohook-napi": "^1.5.5"
  },
  "optionalDependencies": {
    "parakeet-coreml": "^2.2.0"
  },
  "devDependencies": {
    "@effect/language-service": "^0.86.2",
    "@effect/vitest": "^4.0.0-beta.90",
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "effect-solutions": "^0.5.3",
    "electron": "^35.0.3",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.3",
    "prettier": "^3.9.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^6.2.2",
    "vitest": "^3.2.6"
  },
  "build": {
    "appId": "com.vaak.app",
    "productName": "Vaak",
    "publish": {
      "provider": "github",
      "releaseType": "release"
    },
    "npmRebuild": false,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "package.json",
      "resources/icon.png",
      "resources/tray-icon.png",
      "resources/tray-icon@2x.png"
    ],
    "asarUnpack": [
      "**/node_modules/smart-whisper/**/*",
      "**/node_modules/uiohook-napi/**/*",
      "**/node_modules/parakeet-coreml/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.png",
      "target": [
        "dmg"
      ],
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Vaak needs microphone access to transcribe your voice.",
        "NSAppleEventsUsageDescription": "Vaak uses System Events to paste transcribed text into the focused application."
      }
    }
  }
}
